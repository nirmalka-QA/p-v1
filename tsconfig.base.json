{
  "compileOnSave": false,
  "compilerOptions": {
    "composite": true,
    "emitDeclarationOnly": true,
    "importHelpers": true,
    "isolatedModules": true,
    "lib": ["ES2023", "DOM", "DOM.Iterable"],
    "module": "esnext",
    "moduleResolution": "bundler",
    "target": "es2023",
    "jsx": "react-jsx",
    "skipLibCheck": true,

    "strict": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,
    "noImplicitOverride": true,
    "noFallthroughCasesInSwitch": true,
    "forceConsistentCasingInFileNames": true,

    "paths": {
      "@wispr/contracts": ["./libs/contracts/src/index.ts"],
      "@wispr/ui": ["./libs/ui/src/index.ts"],
      "@wispr/tokens": ["./libs/tokens/src/index.ts"],
      "@wispr/services": ["./libs/services/src/index.ts"],
      "@wispr/store": ["./libs/store/src/index.ts"],
      "@wispr/mfe-runtime": ["./libs/mfe-runtime/src/index.ts"],
      "@wispr/projects": ["./libs/projects/src/index.ts"],
      "@wispr/utils": ["./libs/utils/src/index.ts"]
    }
  },
  "exclude": ["node_modules", "tmp"]
}
