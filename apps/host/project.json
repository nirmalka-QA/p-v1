{
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "name": "host",
  "projectType": "application",
  "sourceRoot": "apps/host/src",
  "tags": ["type:app", "scope:host"],
  "//": "Explicit targets (not @nx/vite inference): the @module-federation/vite config hangs Nx's graph-node creation, so host is excluded from @nx/vite in nx.json and runs Vite directly. implicitDependencies makes the host→remote edges visible in the graph (keep in step with tools/mf/remotes.ts).",
  "implicitDependencies": ["custom-app", "data-pipeline", "strategy"],
  "targets": {
    "serve": {
      "executor": "nx:run-commands",
      "options": { "command": "vite", "cwd": "apps/host" },
      "continuous": true
    },
    "dev": {
      "executor": "nx:run-commands",
      "options": { "command": "vite", "cwd": "apps/host" },
      "continuous": true,
      "dependsOn": [{ "projects": ["custom-app", "data-pipeline", "strategy"], "target": "preview" }]
    },
    "build": {
      "executor": "nx:run-commands",
      "options": { "command": "vite build", "cwd": "apps/host" },
      "outputs": ["{projectRoot}/dist"],
      "cache": true
    },
    "preview": {
      "executor": "nx:run-commands",
      "options": { "command": "vite preview --port 4200 --strictPort", "cwd": "apps/host" },
      "dependsOn": ["build"],
      "continuous": true
    },
    "typecheck": {
      "executor": "nx:run-commands",
      "options": { "command": "tsc --noEmit -p tsconfig.app.json", "cwd": "apps/host" },
      "cache": true
    }
  }
}
