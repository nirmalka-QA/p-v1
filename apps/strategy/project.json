{
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "name": "strategy",
  "projectType": "application",
  "sourceRoot": "apps/strategy/src",
  "tags": ["type:app", "scope:remote"],
  "//": "Explicit targets (excluded from @nx/vite inference in nx.json): federation config hangs Nx graph-node creation, so this remote runs Vite directly.",
  "targets": {
    "serve": {
      "executor": "nx:run-commands",
      "options": { "command": "vite", "cwd": "apps/strategy" },
      "continuous": true
    },
    "build": {
      "executor": "nx:run-commands",
      "options": { "command": "vite build", "cwd": "apps/strategy" },
      "outputs": ["{projectRoot}/dist"],
      "cache": true
    },
    "preview": {
      "executor": "nx:run-commands",
      "options": { "command": "vite preview --port 4203 --strictPort", "cwd": "apps/strategy" },
      "dependsOn": ["build"],
      "continuous": true
    },
    "typecheck": {
      "executor": "nx:run-commands",
      "options": { "command": "tsc --noEmit -p tsconfig.app.json", "cwd": "apps/strategy" },
      "cache": true
    }
  }
}
