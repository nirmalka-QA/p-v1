#!/bin/sh
# WISPR pre-commit gate: typecheck the projects affected by the staged changes
# (Nx figures out which). Fast (cached + affected-only).
#
# `lint` is intentionally NOT run yet: workspace ESLint enforcement isn't set up
# (only custom-app has a config, and it has pre-existing rule violations). Add
# `lint` here once the ESLint-enforcement step lands and lint is green.
#
# Bypass intentionally with:  git commit --no-verify
set -e

# Comma-separated list of staged files (Added/Copied/Modified/Renamed).
files=$(git diff --cached --name-only --diff-filter=ACMR | paste -sd, -)
if [ -z "$files" ]; then
  exit 0
fi

echo "[pre-commit] nx affected -t typecheck (staged changes)"
npx nx affected -t typecheck --files="$files"
